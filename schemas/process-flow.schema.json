{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thermal-flow-lab.local/schemas/process-flow.schema.json",
  "title": "ThermalFlow process graph",
  "type": "object",
  "required": ["meta", "systems", "sources", "nodes", "edges"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "version", "dataMode"]
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "shortName", "color"]
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "url"]
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "shortName", "systems", "x", "y", "function", "inputs", "outputs", "evidenceLevel", "sourceIds"]
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "system", "medium", "duration"]
      }
    }
  }
}
