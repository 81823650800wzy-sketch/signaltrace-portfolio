{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sanitized incident case collection",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "title", "primarySystem", "status", "evidenceLevel", "summary", "productOpportunity", "focusNodeIds", "steps"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "title": { "type": "string", "minLength": 1 },
      "primarySystem": { "enum": ["fuel", "steam", "flue", "electric", "waste", "control"] },
      "status": { "enum": ["closed", "tracking", "open"] },
      "evidenceLevel": { "const": "sanitized" },
      "summary": { "type": "string", "minLength": 1 },
      "productOpportunity": { "type": "string", "minLength": 1 },
      "focusNodeIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
      "steps": {
        "type": "array",
        "minItems": 3,
        "items": {
          "type": "object",
          "required": ["id", "label", "detail", "kind"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "label": { "type": "string", "minLength": 1 },
            "detail": { "type": "string", "minLength": 1 },
            "kind": { "enum": ["fact", "inference", "unknown"] },
            "focusNodeIds": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
